# R artifacts
.Rhistory
.RData
.Ruserdata
*.Rproj.user/

# Notebook artifacts
.ipynb_checkpoints/

# OS cruft
.DS_Store
Thumbs.db
~$*
.~lock.*

# Editor cruft
*.swp
*.swo

# Rendered HTML notebooks (large; rebuild from source)
# Comment out the following two lines if you want to commit rendered notebooks
*.nb.html
*.html

# Large data files (data goes to S3, not this repo)
paper-code/data/*.csv
paper-code/data/rds/*.rds

# Internal artifacts that must NOT be published
**/_INTERNAL_DO_NOT_PUBLISH_*
